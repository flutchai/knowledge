{
  "name": "@flutchai/knowledge",
  "version": "0.1.2",
  "description": "NestJS library for knowledge base management with vector search — PostgreSQL (pgvector) and MongoDB backends, OpenAI embeddings, RAG retrieval",
  "author": "Flutchai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flutchai/knowledge.git"
  },
  "homepage": "https://github.com/flutchai/knowledge#readme",
  "bugs": {
    "url": "https://github.com/flutchai/knowledge/issues"
  },
  "keywords": [
    "nestjs",
    "knowledge-base",
    "rag",
    "vector-search",
    "pgvector",
    "mongodb",
    "openai",
    "embeddings",
    "langchain"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/mongodb": "^0.0.6",
    "@langchain/openai": "^0.3.0",
    "@langchain/textsplitters": "^0.1.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "mongodb": "^6.0.0",
    "mongoose": "^8.0.0",
    "pg": "^8.11.0",
    "pgvector": "^0.2.0"
  },
  "packageManager": "yarn@4.13.0",
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10",
    "@types/jest": "^29",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "eslint": "^8",
    "eslint-config-prettier": "^9",
    "jest": "^29",
    "prettier": "^3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "ts-jest": "^29",
    "typescript": "^5.0.0"
  }
}
